<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EcoRide{% endblock %}</title>
    
    <link href="{{ asset('assets/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/css/style.css') }}" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Navigation -->
    {% include 'components/navigation.html.twig' %}

    <!-- Contenu principal -->
    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p>&copy; 2024 EcoRide. Tous droits réservés.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="{{ asset('assets/js/jquery.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.bundle.min.js') }}"></script>
    
    <!-- Vos fichiers de routes -->
    <script src="{{ asset('assets/js/routes/route.js') }}"></script>
    <script src="{{ asset('assets/js/routes/router.js') }}"></script>
    <script src="{{ asset('assets/js/routes/allroute.js') }}"></script>
    
    <!-- Votre JS principal -->
    <script src="{{ asset('assets/js/script.js') }}"></script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>